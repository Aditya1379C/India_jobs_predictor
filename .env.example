# India Tech Jobs — environment configuration
# Copy this file to .env and fill in your API credentials.
# .env is gitignored — never commit real keys.

# ── API source ────────────────────────────────────────────────────────────────
# Which job-listings API to use.  Pick one: adzuna | jsearch
API_SOURCE=adzuna

# ── Adzuna (https://developer.adzuna.com) ─────────────────────────────────────
# Free tier: 250 calls/day.  Sign up → My Apps → create an app to get these.
ADZUNA_APP_ID=your_adzuna_app_id_here
ADZUNA_APP_KEY=your_adzuna_app_key_here

# ── JSearch via RapidAPI (https://rapidapi.com/letscrape-6bfp2kogce/api/jsearch)
# Free tier: 500 calls/month.  Subscribe → copy the X-RapidAPI-Key header value.
JSEARCH_API_KEY=your_rapidapi_key_here

# ── Data quality ──────────────────────────────────────────────────────────────
# Adzuna marks many salaries as model-estimated (salary_is_predicted).
# true  = keep them (more training data, noisier target — default)
# false = treat estimated salaries as "Not Mentioned"
INCLUDE_PREDICTED_SALARIES=true

# ── Scrape coverage ───────────────────────────────────────────────────────────
# Hard cap on HTTP calls per scrape run (Adzuna free tier: 250/day)
MAX_CALLS_PER_RUN=240
# Broad "it-jobs" category sweep per city, in addition to keyword queries
ADZUNA_CATEGORY_SWEEP=true
